<%# locals: (form:, resource:, name:, attribute_name:, type:, value: nil, icon: nil, autofocus: nil, autocomplete: nil) %>

<%- case type %>
<%- when :text %>
  <%= form.label name, class: 'block text-sm/6 font-medium text-gray-900 dark:text-white' %>

  <div class="mt-2 grid grid-cols-1">
    <%- if resource.errors[attribute_name].present? %>
      <%= form.text_field name, value: value, autofocus: autofocus, autocomplete: autocomplete, class: 'col-start-1 row-start-1 block w-full rounded-md bg-neutral-50 dark:bg-neutral-900 py-1.5 px-10 text-base text-gray-900 dark:text-white outline outline-1 -outline-offset-1 outline-red-600 dark:outline-red-400 placeholder:text-red-600 dark:placeholder:text-red-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-red-600 dark:focus:outline-red-400 sm:text-sm/6' %>
    <%- else %>
      <%= form.text_field name, value: value, autofocus: autofocus, autocomplete: autocomplete, class: 'col-start-1 row-start-1 block w-full rounded-md bg-neutral-50 dark:bg-neutral-900 py-1.5 pl-10 pr-3 pl-10 text-base text-gray-900 dark:text-white outline outline-1 -outline-offset-1 outline-primary dark:outline-secondary placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-primary dark:focus:outline-secondary sm:text-sm/6' %>
    <%- end %>

    <%- case icon %>
    <%- when :user %>
      <svg class="pointer-events-none col-start-1 row-start-1 ml-3 size-5 self-center text-primary dark:text-secondary sm:size-4" viewBox="0 0 24 24" fill="currentColor">
        <path fill-rule="evenodd" d="M7.5 6a4.5 4.5 0 1 1 9 0 4.5 4.5 0 0 1-9 0ZM3.751 20.105a8.25 8.25 0 0 1 16.498 0 .75.75 0 0 1-.437.695A18.683 18.683 0 0 1 12 22.5c-2.786 0-5.433-.608-7.812-1.7a.75.75 0 0 1-.437-.695Z" clip-rule="evenodd" />
      </svg>
    <%- end %>

    <%- if resource.errors[attribute_name].present? %>
      <svg class="pointer-events-none col-start-1 row-start-1 mr-3 size-5 self-center justify-self-end text-red-600 dark:text-red-400 sm:size-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" data-slot="icon">
        <path fill-rule="evenodd" d="M8 15A7 7 0 1 0 8 1a7 7 0 0 0 0 14ZM8 4a.75.75 0 0 1 .75.75v3a.75.75 0 0 1-1.5 0v-3A.75.75 0 0 1 8 4Zm0 8a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z" clip-rule="evenodd" />
      </svg>
    <%- end %>
  </div>

  <%- if resource.errors[attribute_name].present? %>
    <p class="mt-0 text-sm text-red-600 dark:text-red-400 absolute"><%= attribute_name.to_s.titlecase + ' ' + resource.errors[attribute_name].first %></p>
  <%- end %>
<%- when :email %>
  <%= form.label name, class: 'block text-sm/6 font-medium text-gray-900 dark:text-white' %>

  <div class="mt-2 grid grid-cols-1">
    <%- if resource.errors[attribute_name].present? %>
      <%= form.email_field name, value: value, autofocus: autofocus, autocomplete: autocomplete, class: 'col-start-1 row-start-1 block w-full rounded-md bg-neutral-50 dark:bg-neutral-900 py-1.5 px-10 text-base text-gray-900 dark:text-white outline outline-1 -outline-offset-1 outline-red-600 dark:outline-red-400 placeholder:text-red-600 dark:placeholder:text-red-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-red-600 dark:focus:outline-red-400 sm:text-sm/6' %>
    <%- else %>
      <%= form.email_field name, value: value, autofocus: autofocus, autocomplete: autocomplete, class: 'col-start-1 row-start-1 block w-full rounded-md bg-neutral-50 dark:bg-neutral-900 py-1.5 pl-10 pr-3 pl-10 text-base text-gray-900 dark:text-white outline outline-1 -outline-offset-1 outline-primary dark:outline-secondary placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-primary dark:focus:outline-secondary sm:text-sm/6' %>
    <%- end %>

    <svg class="pointer-events-none col-start-1 row-start-1 ml-3 size-5 self-center text-primary dark:text-secondary sm:size-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" data-slot="icon">
      <path d="M2.5 3A1.5 1.5 0 0 0 1 4.5v.793c.026.009.051.02.076.032L7.674 8.51c.206.1.446.1.652 0l6.598-3.185A.755.755 0 0 1 15 5.293V4.5A1.5 1.5 0 0 0 13.5 3h-11Z" />
      <path d="M15 6.954 8.978 9.86a2.25 2.25 0 0 1-1.956 0L1 6.954V11.5A1.5 1.5 0 0 0 2.5 13h11a1.5 1.5 0 0 0 1.5-1.5V6.954Z" />
    </svg>

    <%- if resource.errors[attribute_name].present? %>
      <svg class="pointer-events-none col-start-1 row-start-1 mr-3 size-5 self-center justify-self-end text-red-600 dark:text-red-400 sm:size-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" data-slot="icon">
        <path fill-rule="evenodd" d="M8 15A7 7 0 1 0 8 1a7 7 0 0 0 0 14ZM8 4a.75.75 0 0 1 .75.75v3a.75.75 0 0 1-1.5 0v-3A.75.75 0 0 1 8 4Zm0 8a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z" clip-rule="evenodd" />
      </svg>
    <%- end %>
  </div>

  <%- if resource.errors[attribute_name].present? %>
    <p class="mt-0 text-sm text-red-600 dark:text-red-400 absolute"><%= attribute_name.to_s.titlecase + ' ' + resource.errors[attribute_name].first %></p>
  <%- end %>
<%- when :password %>
  <%= form.label name, class: 'block text-sm/6 font-medium text-gray-900 dark:text-white' %>

  <div class="mt-2 grid grid-cols-1">
    <%- if resource.errors[attribute_name].present? %>
      <%= form.password_field name, value: value, autofocus: autofocus, autocomplete: autocomplete, class: 'col-start-1 row-start-1 block w-full rounded-md bg-neutral-50 dark:bg-neutral-900 py-1.5 px-10 text-base text-gray-900 dark:text-white outline outline-1 -outline-offset-1 outline-red-600 dark:outline-red-400 placeholder:text-red-600 dark:placeholder:text-red-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-red-600 dark:focus:outline-red-400 sm:text-sm/6' %>
    <%- else %>
      <%= form.password_field name, value: value, autofocus: autofocus, autocomplete: autocomplete, class: 'col-start-1 row-start-1 block w-full rounded-md bg-neutral-50 dark:bg-neutral-900 py-1.5 pl-10 pr-3 pl-10 text-base text-gray-900 dark:text-white outline outline-1 -outline-offset-1 outline-primary dark:outline-secondary placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-primary dark:focus:outline-secondary sm:text-sm/6' %>
    <%- end %>

    <svg class="pointer-events-none col-start-1 row-start-1 ml-3 size-5 self-center text-primary dark:text-secondary sm:size-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" data-slot="icon">
      <path fill-rule="evenodd" d="M12 1.5a5.25 5.25 0 0 0-5.25 5.25v3a3 3 0 0 0-3 3v6.75a3 3 0 0 0 3 3h10.5a3 3 0 0 0 3-3v-6.75a3 3 0 0 0-3-3v-3c0-2.9-2.35-5.25-5.25-5.25Zm3.75 8.25v-3a3.75 3.75 0 1 0-7.5 0v3h7.5Z" clip-rule="evenodd" />
    </svg>

    <%- if resource.errors[attribute_name].present? %>
      <svg class="pointer-events-none col-start-1 row-start-1 mr-3 size-5 self-center justify-self-end text-red-600 dark:text-red-400 sm:size-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" data-slot="icon">
        <path fill-rule="evenodd" d="M8 15A7 7 0 1 0 8 1a7 7 0 0 0 0 14ZM8 4a.75.75 0 0 1 .75.75v3a.75.75 0 0 1-1.5 0v-3A.75.75 0 0 1 8 4Zm0 8a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z" clip-rule="evenodd" />
      </svg>
    <%- end %>
  </div>

  <%- if resource.errors[attribute_name].present? %>
    <p class="mt-0 text-sm text-red-600 dark:text-red-400 absolute"><%= attribute_name.to_s.titlecase + ' ' + resource.errors[attribute_name].first %></p>
  <%- end %>
<%- when :checkbox %>
  <div class="flex gap-3">
    <div class="flex h-6 shrink-0 items-center">
      <div class="group grid size-4 grid-cols-1">
        <%= form.check_box name, class: 'cursor-pointer col-start-1 row-start-1 appearance-none rounded border border-primary dark:border-secondary bg-neutral-50 dark:bg-neutral-900 checked:border-primary dark:checked:border-secondary checked:bg-primary dark:checked:bg-secondary indeterminate:border-primary dark:indeterminate:border-secondary indeterminate:bg-primary dark:indeterminate:bg-secondary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary dark:focus-visible:outline-secondary disabled:border-gray-300 disabled:bg-gray-100 disabled:checked:bg-gray-100 forced-colors:appearance-auto' %>

        <svg class="pointer-events-none col-start-1 row-start-1 size-3.5 self-center justify-self-center stroke-white dark:stroke-neutral-900 group-has-[:disabled]:stroke-gray-950/25" viewBox="0 0 14 14" fill="none">
          <path class="opacity-0 group-has-[:checked]:opacity-100" d="M3 8L6 11L11 3.5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          <path class="opacity-0 group-has-[:indeterminate]:opacity-100" d="M3 7H11" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </div>
    </div>

    <%= form.label name, class: 'cursor-pointer block text-sm/6 text-primary dark:text-secondary' %>
  </div>
<%- end %>
