<%# locals: (title: nil, notification:, type:) %>

<div data-controller="notification">
  <div data-notification-target="notification" aria-live="assertive" class="hidden z-10 pointer-events-none fixed inset-0 flex items-end px-4 py-6 sm:items-start sm:p-6"
       data-transition-enter="transform ease-out duration-300 transition"
       data-transition-enter-start="translate-y-2 opacity-0 sm:translate-y-0 sm:translate-x-2"
       data-transition-enter-end="translate-y-0 opacity-100 sm:translate-x-0"
       data-transition-leave="transition ease-in duration-100"
       data-transition-leave-start="opacity-100"
       data-transition-leave-end="opacity-0">
    <div class="flex w-full flex-col items-center space-y-4 sm:items-end">
      <div class="pointer-events-auto w-full max-w-sm overflow-hidden rounded-lg bg-white dark:bg-neutral-700 shadow-lg ring-1 ring-black/5">
        <div class="p-4">
          <div class="flex items-start">
            <div class="shrink-0">
              <%- case type %>
              <%- when :notice %>
                <svg xmlns="http://www.w3.org/2000/svg" class="size-6 dark:text-green-400 text-green-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              <%- when :alert %>
                <svg xmlns="http://www.w3.org/2000/svg" class="size-6 dark: dark:text-red-400 text-red-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
                </svg>
              <%- end %>
            </div>

            <div class="ml-3 w-0 flex-1 pt-0.5">
              <%- if title.present? %>
                <p class="mb-1 text-sm font-medium text-gray-900 dark:text-secondary"><%= title %></p>
              <% end %>

              <p class="text-sm text-gray-500 dark:text-white"><%= notification %></p>
            </div>

            <div class="ml-4 flex shrink-0">
              <button type="button" data-action="notification#close" class="inline-flex rounded-md bg-white dark:bg-neutral-700 text-gray-400 dark:text-white dark:hover:text-secondary hover:text-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2">
                <span class="sr-only">Close</span>

                <svg class="size-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" data-slot="icon">
                  <path d="M6.28 5.22a.75.75 0 0 0-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 1 0 1.06 1.06L10 11.06l3.72 3.72a.75.75 0 1 0 1.06-1.06L11.06 10l3.72-3.72a.75.75 0 0 0-1.06-1.06L10 8.94 6.28 5.22Z" />
                </svg>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
