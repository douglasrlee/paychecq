<div class="sm:mx-auto sm:w-full sm:max-w-md">
  <%= picture_tag do %>
    <%= tag(:source, :srcset => image_path('light/logo.svg'), media: '(prefers-color-scheme: light)') %>
    <%= tag(:source, :srcset => image_path('dark/logo.svg'), media: '(prefers-color-scheme: dark)') %>
    <%= image_tag('light/logo.svg', :alt => 'PayChecQ', height: 40, class: 'mx-auto h-10 w-auto') %>
  <% end %>

  <h2 class="mt-6 text-center text-2xl/9 font-bold tracking-tight text-primary dark:text-secondary">Password reset</h2>
</div>

<div class="mt-10 sm:mx-auto sm:w-full sm:max-w-[480px]">
  <div class="bg-neutral-50 dark:bg-neutral-900 px-6 py-12 shadow sm:rounded-lg sm:px-12">
    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, novalidate: true }) do |form| %>
      <div class="space-y-6">
        <div>
          <%= render 'components/form_input', form: form, resource: resource, name: :email, value: nil, attribute_name: :email, type: :email, autofocus: true, autocomplete: 'email' %>
        </div>

        <div class="flex items-center justify-end">
          <div class="text-sm/6">
            <%= link_to "Sign in?", new_session_path(resource_name), class: 'font-semibold text-primary dark:text-secondary hover:text-primary-alt dark:hover:text-secondary-alt' %>
          </div>
        </div>

        <div>
          <%= render 'components/form_button', form: form, name: 'Send reset instructions' %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<p class="mt-10 text-center text-sm/6 text-gray-500 dark:text-gray-300">
  Didn't receive confirmation instructions?
  <%= link_to "Resend", new_confirmation_path(resource_name), class: 'font-semibold text-primary dark:text-secondary hover:text-primary-alt dark:hover:text-secondary-alt' %>
</p>

<p class="mt-2 text-center text-sm/6 text-gray-500 dark:text-gray-300">
  New here?
  <%= link_to "Sign up", new_registration_path(resource_name), class: 'font-semibold text-primary dark:text-secondary hover:text-primary-alt dark:hover:text-secondary-alt' %>
</p>