<% content_for :title, "Goals" %>

<div class="flex flex-col items-center pb-10">
  <div class="w-full max-w-240 mt-10 px-4 flex items-center justify-between gap-3">
    <h2 class="text-2xl font-bold">Goals</h2>
    <% if @funding_schedules.any? %>
      <%= link_to new_goal_path,
            class: "btn btn-primary btn-sm btn-circle",
            "aria-label": "New goal",
            data: { turbo_frame: "drawer_content", action: "click->drawer#open" } do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4" />
        </svg>
      <% end %>
    <% end %>
  </div>

  <%= render "list", goals: @goals, funding_schedules: @funding_schedules %>
</div>
