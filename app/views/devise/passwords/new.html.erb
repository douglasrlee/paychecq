<h5 class="card-title text-center text-primary">Forgot your password?</h5>

<%= simple_form_for(resource, as: resource_name, url: password_path(resource_name)) do |f| %>
  <%= f.input :email, autofocus: true, required: true, wrapper_html: { class: 'mb-3' }, input_html: { autocomplete: 'email' }, as: 'email' %>

  <%= f.button :submit, 'Send instructions', class: 'btn-primary w-100' %>
<% end %>

<%= render "devise/shared/links" %>
