<h5 class="card-title text-center">Sign up</h5>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { novalidate: true }) do |f| %>
  <div class="mt-4">
    <%= f.label :name, for: "name", class: "form-label" %>
    <%= f.text_field :name, autofocus: true, autocomplete: "name", id: "name", name: "name", class: (resource.errors[:name].any? ? "is-invalid form-control" : "form-control") %>
    <div class="invalid-feedback <%= "d-block" if resource.errors[:name].any? %>">
      Name <%= resource.errors[:name].first %>
    </div>
  </div>

  <div class="mt-2">
    <%= f.label :email, "Email address", class: "form-label" %>
    <%= f.email_field :email, autocomplete: "username", class: (resource.errors[:email].any? ? "is-invalid form-control" : "form-control") %>
    <div class="invalid-feedback <%= "d-block" if resource.errors[:email].any? %>">
      Email address <%= resource.errors[:email].first %>
    </div>
  </div>

  <div class="mt-2">
    <%= f.label :password, class: "form-label" %>
    <%= f.password_field :password, autocomplete: "new-password", class: (resource.errors[:password].any? ? "is-invalid form-control" : "form-control") %>
    <div class="invalid-feedback <%= "d-block" if resource.errors[:password].any? %>">
      Password <%= resource.errors[:password].first %>
    </div>
  </div>

  <div class="mt-2">
    <%= f.label :password_confirmation, "Password confirmation", class: "form-label" %>
    <%= f.password_field :password_confirmation, autocomplete: "new-password", class: (resource.errors[:password_confirmation].any? ? "is-invalid form-control" : "form-control") %>
    <div class="invalid-feedback <%= "d-block" if resource.errors[:password_confirmation].any? %>">
      Password confirmation <%= resource.errors[:password_confirmation].first %>
    </div>
  </div>

  <%= f.submit "Sign up", class: "btn btn-primary w-100 mb-2 mt-4" %>
<% end %>

<%= render "devise/shared/links" %>
