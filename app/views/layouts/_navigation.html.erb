<nav class="navbar navbar-expand-sm bg-body-tertiary">
  <div class="container-fluid">
    <%= link_to root_path, class: 'navbar-brand' do %>
      <%= picture_tag do %>
        <%= tag(:source, srcset: image_path('light/logo.svg'), media: '(prefers-color-scheme: light)') %>
        <%= tag(:source, srcset: image_path('dark/logo.svg'), media: '(prefers-color-scheme: dark)') %>
        <%= image_tag('light/logo.svg', alt: 'logo', height: 35) %>
      <% end %>
    <% end %>

    <div class="collapse navbar-collapse">
      <ul class="navbar-nav m-auto">
        <li class="nav-item"><%= link_to 'Transactions', transactions_path, class: current_page?(transactions_path) || current_page?(root_path) ? 'nav-link active' : 'nav-link' %></li>
      </ul>

      <div class="d-flex dropdown">
        <a class="dropdown-toggle btn" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false"><%= image_tag(gravatar_url, alt: 'avatar', height: 33, class: 'rounded-circle') %></a>

        <ul class="dropdown-menu dropdown-menu-end">
          <li>
            <%= link_to settings_path, class: current_page?(settings_path) ? 'dropdown-item active' : 'dropdown-item' do %>
              <i class="bi bi-gear-fill"></i> Settings
            <% end %>
          </li>
          <li>
            <%= link_to destroy_user_session_path, class: 'dropdown-item' do %>
              <i class="bi bi-box-arrow-right"></i> Logout
            <% end %>
          </li>
        </ul>
      </div>
    </div>

    <div class="d-sm-none dropdown">
      <a class="btn" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false"><i class="bi bi-list" style="font-size: 1.5em;"></i></a>

      <ul class="dropdown-menu dropdown-menu-end">
        <li>
          <%= link_to transactions_path, class: current_page?(transactions_path) || current_page?(root_path) ? 'dropdown-item active' : 'dropdown-item' do %>
            <i class="bi bi-cash-stack"></i> Transactions
          <% end %>
        </li>
        <li><hr class="dropdown-divider"></li>
        <li>
          <%= link_to settings_path, class: current_page?(settings_path) ? 'dropdown-item active' : 'dropdown-item' do %>
            <i class="bi bi-gear-fill"></i> Settings
          <% end %>
        </li>
        <li>
          <%= link_to destroy_user_session_path, class: 'dropdown-item' do %>
            <i class="bi bi-box-arrow-right"></i> Logout
          <% end %>
        </li>
      </ul>
    </div>
  </div>
